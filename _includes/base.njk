<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% if title %}{{ title }} | My Site{% else %}My Site{% endif %}</title>
    <link rel="stylesheet" href="{{ '/styles.css' | url }}">
  </head>
  <body>
    <header class="site-header">
      <nav class="nav">
        <a href="{{ '/' | url }}">Home</a>
        <a href="{{ '/about/' | url }}">About</a>
        <a href="{{ '/contact/' | url }}">Contact</a>
      </nav>
    </header>

    <main class="page">
      {{ content | safe }}
    </main>
  </body>
</html>
